# secrets & runtime — never commit
.env
config.json
state/
logs/
inbox/
*.log

# per-user data (memory, personas with real content)
workspaces/*
!workspaces/.gitkeep

# runtime session dirs (generated by start.sh; contain .mcp.json/.claude)
sessions/

# misc
.DS_Store
node_modules/

# real personas (per-user setup; keep only example public)
personas/*
!personas/example/
